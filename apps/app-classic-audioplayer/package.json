{
  "name": "@owdproject/app-classic-audioplayer",
  "version": "0.0.4",
  "description": "Audio Player for your Open Web Desktop client",
  "keywords": [
    "owd-client",
    "owd-apps",
    "owd-modules"
  ],
  "license": "MIT",
  "homepage": "https://github.com/owdproject/app-classic-audioplayer",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "nx": {
    "name": "app-classic-audioplayer"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/app-classic-audioplayer/} nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "validate": "desktop validate ."
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.0",
    "@owdproject/core": "workspace:*",
    "@owdproject/theme-nova": "workspace:*",
    "nuxt": "^4.3.0",
    "typescript": "~5.9.3",
    "@owdproject/module-fs": "workspace:*",
    "@owdproject/module-persistence": "workspace:*"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.2.0"
  }
}
