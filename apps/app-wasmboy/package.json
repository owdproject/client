{
  "name": "@owdproject/app-wasmboy",
  "version": "0.1.0",
  "description": "WasmBoy App for your Open Web Desktop client",
  "keywords": [
    "owd-client",
    "owd-apps",
    "owd-modules",
    "wasmboy"
  ],
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/owdproject/app-wasmboy",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "nx": {
    "name": "app-wasmboy"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/app-wasmboy/} nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "validate": "desktop validate .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.0",
    "json-arraybuffer-reviver": "^2.0.0",
    "wasmboy": "0.7.1"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.1.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.0",
    "@nuxt/test-utils": "^3.23.0",
    "@owdproject/core": "workspace:*",
    "@owdproject/theme-nova": "workspace:*",
    "@types/node": "latest",
    "eslint": "^9.39.2",
    "nuxt": "^4.3.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.2.0"
  }
}
