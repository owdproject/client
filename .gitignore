# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

#desktop
.desktop
/desktop/certs
/apps
/themes

# IDEs and editors
/.idea
.project
.classpath
.cursor
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/
.nx/cache
.nx/workspace-data
._*

# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
vite.config.*.timestamp*
vitest.config.*.timestamp*
*.tsbuildinfo

# Package manager & lock noise
.pnpm-store/
pnpm-debug.log*

# Local overrides (never commit secrets)
.env.local
.env.*.local

# Test / coverage (when generated at repo root)
*.lcov
.nyc_output
