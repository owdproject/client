{
  "name": "@owdproject/theme-win11",
  "version": "0.0.1",
  "description": "Windows 11 desktop theme for OWD clients",
  "homepage": "https://github.com/owdproject/theme-win11#readme",
  "license": "MIT",
  "author": {
    "name": "Diego Villa",
    "url": "https://github.com/dxlliv"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": ["./dist/types.d.mts"]
    }
  },
  "files": ["dist"],
  "nx": { "name": "theme-win11" },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/theme-win11/} nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "validate": "desktop validate ."
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.0",
    "@owdproject/kit-explorer": "workspace:*",
    "@owdproject/kit-fs": "workspace:*",
    "@owdproject/kit-theme": "workspace:*",
    "@owdproject/module-fs": "workspace:*",
    "deepmerge": "^4.3.1",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@owdproject/app-classic-audioplayer": "workspace:*",
    "@owdproject/core": "workspace:*",
    "@owdproject/module-persistence": "workspace:*",
    "nuxt": "^4.3.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.2.0"
  }
}
