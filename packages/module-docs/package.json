{
  "name": "@owdproject/module-docs",
  "version": "0.1.0",
  "description": "Installable Open Web Desktop documentation (Nuxt Content v3)",
  "keywords": [
    "owd-client",
    "owd-modules",
    "nuxt-module",
    "documentation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/owdproject/module-docs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owdproject/module-docs.git"
  },
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs",
      "development": "./src/module.ts"
    },
    "./register": {
      "types": "./src/registerOwdDocsSource.ts",
      "import": "./src/registerOwdDocsSource.ts"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "content"
  ],
  "nx": {
    "name": "module-docs"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/module-docs/} nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "lint": "eslint .",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/content": "^3.13.0",
    "@nuxt/kit": "^4.3.0",
    "defu": "^6.1.4",
    "h3": "^1.15.1"
  },
  "devDependencies": {
    "@owdproject/core": "workspace:*",
    "@owdproject/theme-nova": "workspace:*",
    "@owdproject/app-about": "workspace:*",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.0",
    "@types/node": "latest",
    "nuxt": "^4.3.0",
    "typescript": "~5.9.3",
    "vue-tsc": "^3.2.4"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.2.0",
    "nuxt": "^4.0.0"
  }
}
