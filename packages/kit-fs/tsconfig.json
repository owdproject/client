{
  "extends": "../../tsconfig.module.json",
  "include": [
    "src/runtime",
    "src/module.ts",
    "../../packages/core/types/index.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.d.vue.ts",
    "src/**/*.vue.d.ts"
  ],
  "compilerOptions": {
    "outDir": "dist",
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@owdproject/core/runtime/*": ["../core/runtime/*"],
      "@owdproject/module-fs/runtime/*": ["../../node_modules/@owdproject/module-fs/runtime/*"]
    }
  }
}
