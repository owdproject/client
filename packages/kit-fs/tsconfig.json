{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "skipLibCheck": true,
    "paths": {
      "@owdproject/core/runtime/*": ["../core/runtime/*"],
      "@owdproject/module-fs/runtime/*": ["../module-fs/runtime/*"]
    }
  },
  "include": ["module.ts", "runtime/**/*.ts", "runtime/**/*.vue"]
}
