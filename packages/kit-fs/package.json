{
  "name": "@owdproject/kit-fs",
  "version": "0.0.1",
  "description": "Neutral filesystem explorer UI primitives for OWD themes (not a ZenFS replacement; use @owdproject/module-fs for VFS integration).",
  "license": "MIT",
  "homepage": "https://github.com/owdproject/client#readme",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./runtime/*": {
      "types": "./src/runtime/*",
      "import": "./src/runtime/*"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": ["./dist/types.d.mts"]
    }
  },
  "files": ["dist", "src/runtime"],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare",
    "dev:prepare": "nuxt-module-build build --stub",
    "build:module": "nuxt-module-build build"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.4",
    "@zenfs/core": "^2.2.3",
    "vue3-selecto": "^1.12.3"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.0",
    "@owdproject/core": "workspace:*",
    "nuxt": "^4.3.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.2.0",
    "@owdproject/module-fs": "^0.0.3",
    "nuxt": "^4.0.0",
    "vue": "^3.5.0"
  }
}
