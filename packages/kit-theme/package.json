{
  "name": "@owdproject/kit-theme",
  "version": "0.0.4",
  "description": "Optional shared shell patterns for OWD themes (neutral composables, no visual chrome).",
  "license": "MIT",
  "homepage": "https://github.com/owdproject/client#readme",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./runtime/*": {
      "types": "./src/runtime/*",
      "import": "./src/runtime/*"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": ["./dist/types.d.mts"]
    }
  },
  "files": ["dist", "src/runtime"],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare",
    "dev:prepare": "nuxt-module-build build --stub",
    "build:module": "nuxt-module-build build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.4"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.0",
    "@owdproject/core": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.6",
    "jsdom": "~29.1.1",
    "nuxt": "^4.3.0",
    "pinia": "^3.0.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.0"
  },
  "optionalDependencies": {
    "html2canvas": "^1.4.1"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.3.0",
    "@vueuse/core": "^14.0.0",
    "nuxt": "^4.0.0",
    "vue": "^3.5.0"
  }
}
