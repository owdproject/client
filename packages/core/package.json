{
  "name": "@owdproject/core",
  "version": "3.2.0",
  "description": "Nuxt Desktop module for browser desktop experiences (windows, shell, apps)",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt-desktop",
    "desktop",
    "web-desktop",
    "vue",
    "owd",
    "open-web-desktop"
  ],
  "homepage": "https://github.com/owdproject/client#readme",
  "bugs": {
    "url": "https://github.com/owdproject/client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owdproject/client.git"
  },
  "license": "MIT",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "types": "types/index.d.ts",
  "files": [
    "bin",
    "dist",
    "runtime",
    "types",
    "index.ts",
    "module.ts",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "pnpm run dev:prepare && cd playground && nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && cd playground && pnpm exec nuxt prepare",
    "build:module": "nuxt-module-build build",
    "prepack": "nuxt-module-build build"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.ts"
    },
    "./module": {
      "types": "./dist/types.d.mts",
      "development": "./module.ts",
      "import": "./module.ts",
      "default": "./module.ts"
    },
    "./nuxt": {
      "types": "./dist/types.d.mts",
      "development": "./module.ts",
      "import": "./module.ts",
      "default": "./module.ts"
    },
    "./package.json": "./package.json",
    "./runtime/*": {
      "types": "./runtime/*",
      "development": "./runtime/*",
      "import": "./runtime/*",
      "default": "./runtime/*"
    }
  },
  "bin": {
    "desktop": "bin/desktop.js",
    "owd": "bin/owd.js"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/kit": "^4.4.4",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.5",
    "@primevue/nuxt-module": "^4.5.5",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "mitt": "^3.0.1",
    "nanoid": "^5.1.11",
    "nuxt": "^4.4.4",
    "pinia": "^3.0.4",
    "sanitize.css": "^13.0.0",
    "sass": "^1.99.0",
    "shellwords": "^1.1.1",
    "vue-resizable": "^2.1.7",
    "getopts": "^2.3.0",
    "neo-blessed": "^0.2.0"
  },
  "optionalDependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.4",
    "typescript": "~5.8.3",
    "vue-tsc": "^2.2.10"
  }
}
