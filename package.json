{
  "name": "owd-client",
  "private": true,
  "description": "Open Web Desktop client",
  "homepage": "https://github.com/dxlliv/client#readme",
  "bugs": {
    "url": "https://github.com/dxlliv/client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owdproject/client.git"
  },
  "license": "MIT",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "scripts": {
    "preinstall": "git submodule update --init --recursive || true",
    "postinstall": "pnpm run prepare:stubs",
    "desktop": "desktop",
    "dev": "pnpm --filter desktop run dev",
    "generate": "pnpm --filter desktop run generate",
    "prepare:stubs": "node scripts/prepare-stubs.mjs",
    "prepare:modules": "pnpm run prepare:stubs && pnpm -r --filter \"!./packages/module-fs\" --filter \"!./themes/*\" --filter \"!./packages/*\" --filter \"./apps/*\" --if-present run dev:prepare",
    "prepare:apps": "pnpm -r --filter \"./apps/*\" --if-present run dev:prepare",
    "prepare:themes": "pnpm -r --filter \"./themes/*\" --if-present run dev:prepare",
    "template:sync": "desktop template",
    "validate:modules": "desktop validate",
    "install-app": "node scripts/install-app.mjs",
    "release:core:dry-run": "changelogen --dry-run",
    "release:theme-nova:dry-run": "changelogen --dir=\"themes/theme-nova\" --dry-run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^4.4.4",
    "@nuxt/ui-templates": "^1.3.4",
    "@owdproject/cli": "workspace:*",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.1",
    "@swc/core": "~1.15.32",
    "@swc/helpers": "~0.5.21",
    "@types/node": "25.6.0",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "changelogen": "^0.6.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "jiti": "2.6.1",
    "jsdom": "~29.1.1",
    "nuxt": "^4.4.4",
    "prettier": "^3.8.3",
    "ts-morph": "^25.0.1",
    "tslib": "^2.8.1",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.7"
  },
  "packageManager": "pnpm@11.7.0"
}