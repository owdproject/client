+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "title": "InstallAppExecutor",
+  "description": "Install an OWD desktop app package into desktop/ and register it in desktop.config.ts.",
+  "type": "object",
+  "properties": {
+    "name": {
+      "type": "string",
+      "description": "Package name (e.g. @owdproject/app-todo)."
+    }
+  },
+  "required": ["name"],
+  "additionalProperties": false
+}
